{
  "name": "descubreme",
  "version": "0.0.0",
  "private": true,
  "description": "DescubreMe — plataforma web de autoconocimiento profundo para adultos LATAM",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test:unit": "vitest run --reporter=verbose",
    "test:unit:watch": "vitest",
    "test:lint": "vitest run tests/lint/ --reporter=verbose",
    "test:e2e": "playwright test --reporter=line",
    "test:all": "npm run test:unit && npm run test:e2e",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.668.0",
    "@date-fns/tz": "^1.2.0",
    "@react-email/components": "^1.0.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.45.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.34.3",
    "@vercel/oidc-aws-credentials-provider": "^3.1.3",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.34.1",
    "nanoid": "^5.0.9",
    "next": "^16.2.7",
    "pino": "^9.14.0",
    "postcss": "^8.5.15",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.16.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/ui": "^2.1.9",
    "drizzle-kit": "^0.27.2",
    "jsdom": "^25.0.1",
    "playwright": "^1.60.0",
    "supabase": "^2.0.0",
    "vitest": "^2.1.9"
  }
}
