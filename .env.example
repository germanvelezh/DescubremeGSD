# =====================================================================
# DescubreMe — .env.example (Phase 1)
# =====================================================================
#
# Este archivo es el contrato de env vars. Se commitea con placeholders.
# Para ejecutar localmente:
#   cp .env.example .env.local
# y reemplaza los placeholders con valores reales obtenidos del checkpoint
# de provisioning (Plan 01-01 Task 1) — los identificadores no-secretos
# estan documentados en estado/STATUS.md; los secretos viven en
# ~/secrets/descubreme/.env.secrets (fuera del repo) y en Vercel env vars.
#
# Reglas:
#   1. NUNCA commitear .env.local ni .env (ambos en .gitignore).
#   2. Variables con prefijo NEXT_PUBLIC_ se bundlean al cliente (browser).
#      Todo lo demas es server-only.
#   3. AWS_REGION debe estar EXPLICITO. Sin esto, llamadas KMS desde
#      Vercel Functions caen a region random — InvalidSignatureException
#      opaco. Ver Vercel docs OIDC + AWS y ADR-006.
#   4. Para dev sin AWS KMS: setea DEV_PII_SECRET (32 bytes hex) y deja
#      AWS_ROLE_ARN vacio. El switch lo decide lib/crypto/pii.ts en
#      runtime. Ver Plan 01-07.
#
# =====================================================================


# ---------------------------------------------------------------------
# Supabase — Auth + DB + Storage (us-east-1, ADR-002)
# ---------------------------------------------------------------------
# Project: dilxhpbfqlvpbzgpshlr.supabase.co (placeholder — confirmar tras
# reset si German hizo merge de proyectos)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxxx
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Drizzle migrations exige direct connection (port 5432); runtime usa
# transaction pooler (port 6543). Dos vars separadas: ver PATTERNS.md §4.
DATABASE_URL=postgresql://postgres.your-project-ref:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres


# ---------------------------------------------------------------------
# Vercel — App hosting + Functions + OIDC federation (D4.1)
# ---------------------------------------------------------------------
VERCEL_TEAM_SLUG=germanvelezhs-projects
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---------------------------------------------------------------------
# AWS KMS — Envelope encryption de PII (ADR-006)
# ---------------------------------------------------------------------
# Asume role descubreme-prod-encrypt via OIDC federation con Vercel.
# NO static AWS access keys: Vercel emite JWT, AWS IAM lo valida, asume
# role temporal. Ver trust policy + permission policy en Plan 01-07.
AWS_ROLE_ARN=arn:aws:iam::000000000000:role/descubreme-prod-encrypt

# CRITICO: Vercel docs warning. AWS_REGION debe ser EXPLICITO. Sin esto,
# Vercel Functions caen a region random — falla con InvalidSignature.
AWS_REGION=us-east-1

# Alias estable. Si rotamos a v2 en el futuro, solo cambia el alias —
# el codigo no se toca. AWS_KMS_KEY_ID directo seria fragil.
AWS_KMS_KEY_ALIAS=alias/descubreme-prod-pii-kek-v1


# ---------------------------------------------------------------------
# Dev local — Mock PII encryption (alternativa a AWS KMS)
# ---------------------------------------------------------------------
# Solo para desarrollo local sin OIDC trust configurado. lib/crypto/pii.ts
# usa esto cuando AWS_ROLE_ARN esta vacio. NEVER commitear el valor.
# Generar con: openssl rand -hex 32
DEV_PII_SECRET=


# ---------------------------------------------------------------------
# Resend — Email transaccional (D3.7)
# ---------------------------------------------------------------------
# API key con scope minimo: Sending Access, scoped a descubreme.co.
# Sender domain verificado en Resend Domains: descubreme.co
# Records DNS en Hostinger: send.descubreme.co (MX+SPF), resend._domainkey
# (DKIM), _dmarc (DMARC p=none).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_SENDER_EMAIL=noreply@descubreme.co


# ---------------------------------------------------------------------
# Upstash Redis — Rate limit magic-link (D2.6, 1/60s, 5/h/email)
# ---------------------------------------------------------------------
# Tipo: Global (aceptado para MVP, ver [ACCEPTED-RISK-UPSTASH-GLOBAL]).
# REST API porque Vercel Edge no soporta TCP raw.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=AaIRACQgxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---------------------------------------------------------------------
# Sentry — Error monitoring con beforeSend redact PII (COMPL-14)
# ---------------------------------------------------------------------
# DSN se bundlea al cliente; el AUTH_TOKEN es server-only (build-time
# para sourcemap upload). Redact PII en sentry.client.config + server
# config con beforeSend hook — implementado en Plan 01-10.
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oNNNNNNN.ingest.sentry.io/PPPPPPP
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oNNNNNNN.ingest.sentry.io/PPPPPPP
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENTRY_ORG=descubreme
SENTRY_PROJECT=descubreme-web


# ---------------------------------------------------------------------
# App config
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
